include README.md
include CHANGELOG.md
include RELEASING.md
include requirements*.txt
include yolo11n.pt
include yolo11n-pose.pt
recursive-include configs *.yaml *.md
recursive-include configs/sample_pose_cache *.json.gz
recursive-include models *.task *.md
recursive-include webui/templates *.html
recursive-include webui/static *.js *.mjs *.css *.wasm
prune outputs
prune .cache
